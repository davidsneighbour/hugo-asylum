{
  "name": "@davidsneighbour/hugo-asylum",
  "description": "Test cases, issue recreation and bug hunting for Hugo",
  "version": "3000.0.0",
  "license": "MIT",
  "repository": "davidsneighbour/hugo-asylum.git",
  "author": "Patrick Kollitsch <davidsneighbourdev+gh@gmail.com>",
  "bugs": {
    "url": "https://github.com/davidsneighbour/hugo-asylum/issues"
  },
  "homepage": "https://github.com/davidsneighbour/hugo-asylum",
  "devDependencies": {
    "@davidsneighbour/release-config": "2026.0.5",
    "@release-it/conventional-changelog": "11.0.0",
    "@tailwindcss/cli": "4.2.4",
    "release-it": "20.0.1",
    "tailwindcss": "4.2.4"
  },
  "scripts": {
    "build": "hugo --gc --environment production",
    "check": "hugo --gc --environment production",
    "server": "hugo server --gc --environment development --disableFastRender --navigateToChanged --buildDrafts --buildFuture --bind 127.0.0.1 --baseURL http://127.0.0.1:1313/",
    "release": "release-it"
  }
}
